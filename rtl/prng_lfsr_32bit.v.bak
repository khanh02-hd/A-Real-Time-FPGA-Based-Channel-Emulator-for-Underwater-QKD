`timescale 1ns / 1ps
module prng_lfsr_32bit #(
    parameter SEED = 32'hDEADBEEF
)(
    input  wire        clk,
    input  wire        rst_n,
    output reg  [31:0] lfsr_out
);
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n)
            lfsr_out <= SEED;
        else
            lfsr_out <= {lfsr_out[30:0], lfsr_out[31] ^ lfsr_out[21] ^ lfsr_out[1] ^ lfsr_out[0]};
    end
endmodule